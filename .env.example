# ─── PulseChat environment template (Technical Spec §17) ────────────────────
# Copy to `.env` for local development. Real values are provisioned manually by
# the project owner (Build Instructions §4) and pasted into each host's
# environment-variable store — never committed to source.
#
# DEV FALLBACKS: when an optional provider key below is absent in development,
# the API logs the would-be email/upload/captcha action instead of calling the
# provider, so the app runs before every account exists.

# ── Required from M0 ─────────────────────────────────────────────────────────
# Supabase Postgres connection string (Project Settings → Database → URI).
# MANUAL STEP: create the free Supabase project and paste the URI here.
DATABASE_URL="postgresql://postgres:password@db.xxxxxxxx.supabase.co:5432/postgres"

# API process
NODE_ENV="development"
PORT="4000"

# CORS + link generation (magic links, invites). The web app's origin.
APP_ORIGIN="http://localhost:8000"

# ── Required from M1 (auth) ──────────────────────────────────────────────────
# Token signing secrets — generate two distinct long random strings, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""

# Brevo transactional email (verification, magic link, OTP, new-device confirm).
# Dev fallback: emails are logged to the API console when unset.
BREVO_API_KEY=""

# Cloudflare Turnstile CAPTCHA (signup/login). Dev fallback: check skipped when unset.
TURNSTILE_SECRET=""

# Cloudinary — signed direct-upload tokens (avatars M1, attachments M4, posts M6).
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=""

# ── Required from M5 (calls/live) ────────────────────────────────────────────
# Shared secret for short-lived TURN credentials (must match coturn's
# static-auth-secret in infra/coturn/turnserver.conf).
TURN_SHARED_SECRET=""
# Public hostname/IP of the self-hosted coturn VM, e.g. turn.example.com
TURN_HOST=""

# ── Required from M7 (push notifications) ────────────────────────────────────
# Web Push VAPID keypair — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# ── Required from M9 (trending movies) ───────────────────────────────────────
# Free-tier API key from themoviedb.org. Unset means the trending sweep
# skips movies and only refreshes Deezer songs (which need no key at all).
TMDB_API_KEY=""

# ── Frontend build-time variables (apps/web, Vite `VITE_` prefix) ────────────
VITE_API_URL="http://localhost:4000"
VITE_TURNSTILE_SITE_KEY=""
VITE_VAPID_PUBLIC_KEY=""
